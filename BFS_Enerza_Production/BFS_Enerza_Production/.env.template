# BFS Enerza — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit the filled .env to version control

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=generate-with-openssl-rand-hex-32

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change_this_strong_password
# DATABASE_URL is constructed in docker-compose from DB_PASSWORD

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password

# ── Payment Gateways (live credentials from provider dashboards) ─────────────
# Razorpay: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# PayU: https://onboarding.payu.in/
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# BBPS: Apply at https://www.npci.org.in/what-we-do/bharat-billpay
BBPS_AGENT_ID=
BBPS_API_KEY=

# ── Notifications ────────────────────────────────────────────────────────────
# Firebase: https://console.firebase.google.com → Project Settings → Cloud Messaging
FCM_SERVER_KEY=

# AWS SNS for SMS: https://console.aws.amazon.com/sns
SMS_API_KEY=your_aws_sns_access_key
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=bfs-enerza-docs

# SMTP (Gmail: enable App Password at myaccount.google.com/security)
SMTP_USER=
SMTP_PASS=

# ── KYC (UIDAI) ──────────────────────────────────────────────────────────────
# Apply for AUA/KUA code at https://uidai.gov.in/
UIDAI_AUA_CODE=
UIDAI_LICENSE_KEY=

# ── GSTN ────────────────────────────────────────────────────────────────────
# Register at https://developer.gst.gov.in/
GSTN_API_KEY=
