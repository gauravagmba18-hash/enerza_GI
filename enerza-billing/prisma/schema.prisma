generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  customerId   String          @id @default(cuid()) @map("customer_id")
  fullName     String          @map("full_name")
  customerType String          @map("customer_type")
  kycStatus    String          @map("kyc_status")
  panRef       String?         @map("pan_ref")
  aadhaarRef   String?         @map("aadhaar_ref")
  mobile       String
  email        String?
  status       String          @default("ACTIVE")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  segmentId    String          @map("segment_id")
  accounts     Account[]
  appUser      AppUser?
  segment      ConsumerSegment @relation(fields: [segmentId], references: [segmentId])
  serviceRequests ServiceRequest[]

  @@index([status])
  @@index([segmentId])
  @@map("customer")
}

model ConsumerSegment {
  segmentId          String              @id @default(cuid()) @map("segment_id")
  segmentName        String              @map("segment_name")
  utilityType        String              @map("utility_type")
  description        String?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  customers          Customer[]
  ratePlans          RatePlan[]
  serviceConnections ServiceConnection[]

  @@map("consumer_segment")
}

model Premise {
  premiseId    String    @id @default(cuid()) @map("premise_id")
  addressLine1 String    @map("address_line1")
  addressLine2 String?   @map("address_line2")
  geoLat       Float?    @map("geo_lat")
  geoLon       Float?    @map("geo_lon")
  buildingType String?   @map("building_type")
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  areaId       String    @map("area_id")
  accounts     Account[]
  area         CgdArea   @relation(fields: [areaId], references: [areaId])

  @@map("premise")
}

model Account {
  accountId          String              @id @default(cuid()) @map("account_id")
  bpType             String?             @map("bp_type")
  billDeliveryMode   String              @map("bill_delivery_mode")
  status             String              @default("ACTIVE")
  effectiveFrom      DateTime            @map("effective_from")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  customerId         String              @map("customer_id")
  premiseId          String              @map("premise_id")
  cycleId            String              @map("cycle_id")
  customer           Customer            @relation(fields: [customerId], references: [customerId])
  premise            Premise             @relation(fields: [premiseId], references: [premiseId])
  cycle              BillCycle           @relation(fields: [cycleId], references: [cycleId])
  appAccountLinks    AppAccountLink[]
  appServiceRequests AppServiceRequest[]
  bills              Bill[]
  budgetBillingPlans BudgetBillingPlan[]
  dunningNotices     DunningNotice[]
  netMeteringCredits NetMeteringCredit[]
  paymentOrders      PaymentOrder[]
  securityDeposits   SecurityDeposit[]
  serviceConnections ServiceConnection[]
  serviceTickets     ServiceTicket[]
  serviceRequests    ServiceRequest[]

  @@index([status])
  @@index([customerId])
  @@index([premiseId])
  @@map("account")
}

model ServiceConnection {
  connectionId    String              @id @default(cuid()) @map("connection_id")
  podId           String?             @map("pod_id")
  utilityType     String              @map("utility_type")
  startDate       DateTime            @map("start_date")
  endDate         DateTime?           @map("end_date")
  status          String              @default("ACTIVE")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  accountId       String              @map("account_id")
  segmentId       String              @map("segment_id")
  bills           Bill[]
  elecConnDetail  ElecConnDetail?
  gasConnDetail   GasConnDetail?
  meterInstalls   MeterInstallation[]
  meterReadings   MeterReading[]
  account         Account             @relation(fields: [accountId], references: [accountId])
  segment         ConsumerSegment     @relation(fields: [segmentId], references: [segmentId])
  waterConnDetail WaterConnDetail?

  @@index([status])
  @@index([accountId])
  @@index([utilityType])
  @@map("service_connection")
}

model GasConnDetail {
  connectionId    String            @id @map("connection_id")
  serviceType     String            @map("service_type")
  regulatorSerial String?           @map("regulator_serial")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  pressureBandId  String            @map("pressure_band_id")
  pressureBand    PressureBand      @relation(fields: [pressureBandId], references: [bandId])
  connection      ServiceConnection @relation(fields: [connectionId], references: [connectionId])

  @@map("gas_conn_detail")
}

model ElecConnDetail {
  connectionId            String                   @id @map("connection_id")
  loadKw                  Float?                   @map("load_kw")
  supplyVoltage           String?                  @map("supply_voltage")
  phaseType               String?                  @map("phase_type")
  tariffCategory          String?                  @map("tariff_category")
  contractDemandKva       Float?                   @map("contract_demand_kva")
  isNetMetered            Boolean                  @default(false) @map("is_net_metered")
  solarCapacityKw         Float?                   @map("solar_capacity_kw")
  dtId                    String?                  @map("dt_id")
  createdAt               DateTime                 @default(now()) @map("created_at")
  updatedAt               DateTime                 @updatedAt @map("updated_at")
  connection              ServiceConnection        @relation(fields: [connectionId], references: [connectionId])
  distributionTransformer DistributionTransformer? @relation(fields: [dtId], references: [dtId])

  @@map("elec_conn_detail")
}

model WaterConnDetail {
  connectionId String            @id @map("connection_id")
  pipeSizeMm   Float?            @map("pipe_size_mm")
  supplyZoneId String?           @map("supply_zone_id")
  meterType    String?           @map("meter_type")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  supplyZone   SupplyZone?       @relation(fields: [supplyZoneId], references: [supplyZoneId])
  connection   ServiceConnection @relation(fields: [connectionId], references: [connectionId])

  @@map("water_conn_detail")
}

model SupplyZone {
  supplyZoneId String            @id @default(cuid()) @map("supply_zone_id")
  name         String
  utilityType  String            @default("WATER") @map("utility_type")
  status       String            @default("ACTIVE")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  bulkReads    BulkMeterRead[]
  waterDetails WaterConnDetail[]

  @@map("supply_zone")
}

model BulkMeterRead {
  readId       String     @id @default(cuid()) @map("read_id")
  supplyZoneId String     @map("supply_zone_id")
  readDate     DateTime   @map("read_date")
  valueScm     Float      @map("value_scm")
  status       String     @default("FINAL")
  createdAt    DateTime   @default(now()) @map("created_at")
  supplyZone   SupplyZone @relation(fields: [supplyZoneId], references: [supplyZoneId])

  @@index([supplyZoneId, readDate])
  @@map("bulk_meter_read")
}

model PressureBand {
  bandId         String          @id @default(cuid()) @map("band_id")
  bandName       String          @map("band_name")
  minPressure    Float           @map("min_pressure")
  maxPressure    Float           @map("max_pressure")
  usageClass     String          @map("usage_class")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  gasConnDetails GasConnDetail[]

  @@map("pressure_band")
}

model RatePlan {
  ratePlanId       String            @id @default(cuid()) @map("rate_plan_id")
  planName         String            @map("plan_name")
  utilityType      String            @map("utility_type")
  effectiveFrom    DateTime          @map("effective_from")
  effectiveTo      DateTime?         @map("effective_to")
  billingFreq      String            @map("billing_freq")
  status           String            @default("ACTIVE")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  segmentId        String            @map("segment_id")
  chargeComponents ChargeComponent[]
  segment          ConsumerSegment   @relation(fields: [segmentId], references: [segmentId])

  @@map("rate_plan")
}

model ChargeComponent {
  componentId   String     @id @default(cuid()) @map("component_id")
  componentName String     @map("component_name")
  componentType String     @map("component_type")
  uom           String?
  rate          Float
  postingClass  String?    @map("posting_class")
  slabFrom      Int?       @map("slab_from")
  slabTo        Int?       @map("slab_to")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  ratePlanId    String     @map("rate_plan_id")
  billLines     BillLine[]
  ratePlan      RatePlan   @relation(fields: [ratePlanId], references: [ratePlanId])

  @@map("charge_component")
}

model TaxMaster {
  taxId         String    @id @default(cuid()) @map("tax_id")
  taxName       String    @map("tax_name")
  jurisdiction  String
  taxRate       Float     @map("tax_rate")
  applicability String
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("tax_master")
}

model BillCycle {
  cycleId      String    @id @default(cuid()) @map("cycle_id")
  cycleName    String    @map("cycle_name")
  readDateRule String    @map("read_date_rule")
  billDateRule String    @map("bill_date_rule")
  dueDateRule  String    @map("due_date_rule")
  graceDays    Int       @default(0) @map("grace_days")
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  accounts     Account[]
  bills        Bill[]

  @@map("bill_cycle")
}

model Bill {
  billId             String              @id @default(cuid()) @map("bill_id")
  billDate           DateTime            @map("bill_date")
  dueDate            DateTime            @map("due_date")
  netAmount          Float               @map("net_amount")
  taxAmount          Float               @map("tax_amount")
  totalAmount        Float               @map("total_amount")
  status             String              @default("PENDING")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  accountId          String              @map("account_id")
  connectionId       String              @map("connection_id")
  cycleId            String              @map("cycle_id")
  account            Account             @relation(fields: [accountId], references: [accountId])
  connection         ServiceConnection   @relation(fields: [connectionId], references: [connectionId])
  cycle              BillCycle           @relation(fields: [cycleId], references: [cycleId])
  billLines          BillLine[]
  dunningNotices     DunningNotice[]
  netMeteringCredits NetMeteringCredit[]
  paymentOrders      PaymentOrder[]

  @@index([status])
  @@index([accountId])
  @@map("bill")
}

model BillLine {
  lineId      String          @id @default(cuid()) @map("line_id")
  description String?
  quantity    Float
  rate        Float
  amount      Float
  lineType    String          @map("line_type")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  billId      String          @map("bill_id")
  componentId String          @map("component_id")
  bill        Bill            @relation(fields: [billId], references: [billId])
  component   ChargeComponent @relation(fields: [componentId], references: [componentId])

  @@map("bill_line")
}

model PaymentChannel {
  channelId     String         @id @default(cuid()) @map("channel_id")
  channelName   String         @map("channel_name")
  channelType   String         @map("channel_type")
  provider      String?
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  paymentOrders PaymentOrder[]

  @@map("payment_channel")
}

model PaymentGateway {
  gatewayId     String         @id @default(cuid()) @map("gateway_id")
  provider      String
  merchantId    String         @map("merchant_id")
  callbackUrl   String         @map("callback_url")
  environment   String         @default("SANDBOX")
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  paymentOrders PaymentOrder[]
  settlements   Settlement[]

  @@map("payment_gateway")
}

model PaymentOrder {
  orderId        String         @id @default(cuid()) @map("order_id")
  amount         Float
  convenienceFee Float          @default(0) @map("convenience_fee")
  status         String         @default("INITIATED")
  initiatedAt    DateTime       @default(now()) @map("initiated_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  billId         String         @map("bill_id")
  accountId      String         @map("account_id")
  channelId      String         @map("channel_id")
  gatewayId      String         @map("gateway_id")
  gatewayTxns    GatewayTxn[]
  bill           Bill           @relation(fields: [billId], references: [billId])
  account        Account        @relation(fields: [accountId], references: [accountId])
  channel        PaymentChannel @relation(fields: [channelId], references: [channelId])
  gateway        PaymentGateway @relation(fields: [gatewayId], references: [gatewayId])
  refund         Refund?

  @@index([status])
  @@index([accountId])
  @@map("payment_order")
}

model GatewayTxn {
  txnId          String          @id @default(cuid()) @map("txn_id")
  gatewayRef     String?         @map("gateway_ref")
  gatewayStatus  String          @map("gateway_status")
  responseAt     DateTime?       @map("response_at")
  settledAt      DateTime?       @map("settled_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  orderId        String          @map("order_id")
  settlementId   String?         @map("settlement_id")
  order          PaymentOrder    @relation(fields: [orderId], references: [orderId])
  settlement     Settlement?     @relation(fields: [settlementId], references: [settlementId])
  suspenseRecord SuspenseRecord?

  @@map("gateway_txn")
}

model Settlement {
  settlementId   String         @id @default(cuid()) @map("settlement_id")
  settlementDate DateTime       @map("settlement_date")
  grossAmount    Float          @map("gross_amount")
  netAmount      Float          @map("net_amount")
  matchedCount   Int            @default(0) @map("matched_count")
  exceptionCount Int            @default(0) @map("exception_count")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  gatewayId      String         @map("gateway_id")
  gatewayTxns    GatewayTxn[]
  gateway        PaymentGateway @relation(fields: [gatewayId], references: [gatewayId])

  @@map("settlement")
}

model Refund {
  refundId    String       @id @default(cuid()) @map("refund_id")
  reasonCode  String?      @map("reason_code")
  amount      Float
  status      String       @default("INITIATED")
  initiatedAt DateTime     @default(now()) @map("initiated_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  orderId     String       @unique @map("order_id")
  order       PaymentOrder @relation(fields: [orderId], references: [orderId])

  @@map("refund")
}

model SuspenseRecord {
  suspenseId       String     @id @default(cuid()) @map("suspense_id")
  reason           String?
  amount           Float
  resolutionStatus String     @default("OPEN") @map("resolution_status")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  txnId            String     @unique @map("txn_id")
  txn              GatewayTxn @relation(fields: [txnId], references: [txnId])

  @@map("suspense_record")
}

model CgdArea {
  areaId      String       @id @default(cuid()) @map("area_id")
  areaName    String       @map("area_name")
  city        String
  district    String
  state       String
  zone        String?
  utilityType String       @map("utility_type")
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  cngStations CngStation[]
  premises    Premise[]
  routes      Route[]

  @@map("cgd_area")
}

model Route {
  routeId       String         @id @default(cuid()) @map("route_id")
  routeName     String         @map("route_name")
  cycleGroup    String?        @map("cycle_group")
  readerId      String?        @map("reader_id")
  status        String         @default("ACTIVE")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  areaId        String         @map("area_id")
  meterReadings MeterReading[]
  area          CgdArea        @relation(fields: [areaId], references: [areaId])

  @@map("route")
}

model Meter {
  meterId            String              @id @default(cuid()) @map("meter_id")
  serialNo           String              @unique @map("serial_no")
  meterType          String              @map("meter_type")
  make               String?
  model              String?
  uom                String?
  utilityType        String              @map("utility_type")
  calibrationDue     DateTime?           @map("calibration_due")
  status             String              @default("ACTIVE")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  installations      MeterInstallation[]
  meterIntervalReads MeterIntervalRead[]
  readings           MeterReading[]

  @@index([status])
  @@map("meter")
}

model MeterInstallation {
  installId    String            @id @default(cuid()) @map("install_id")
  installDate  DateTime          @map("install_date")
  removeDate   DateTime?         @map("remove_date")
  sealNo       String?           @map("seal_no")
  reason       String?
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  meterId      String            @map("meter_id")
  connectionId String            @map("connection_id")
  meter        Meter             @relation(fields: [meterId], references: [meterId])
  connection   ServiceConnection @relation(fields: [connectionId], references: [connectionId])

  @@map("meter_installation")
}

model MeterReading {
  readingId    String            @id @default(cuid()) @map("reading_id")
  readingDate  DateTime          @map("reading_date")
  readingValue Float             @map("reading_value")
  consumption  Float
  kvah         Float?
  maxDemand    Float?            @map("max_demand")
  readingType  String            @map("reading_type")
  status       String            @default("PENDING")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  meterId      String            @map("meter_id")
  connectionId String            @map("connection_id")
  routeId      String            @map("route_id")
  meter        Meter             @relation(fields: [meterId], references: [meterId])
  connection   ServiceConnection @relation(fields: [connectionId], references: [connectionId])
  route        Route             @relation(fields: [routeId], references: [routeId])

  @@map("meter_reading")
}

model CngStation {
  stationId      String    @id @default(cuid()) @map("station_id")
  stationName    String    @map("station_name")
  city           String
  compressorType String?   @map("compressor_type")
  dispenserCount Int       @default(0) @map("dispenser_count")
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  areaId         String    @map("area_id")
  cngSales       CngSale[]
  area           CgdArea   @relation(fields: [areaId], references: [areaId])

  @@map("cng_station")
}

model VehicleCategory {
  categoryId     String    @id @default(cuid()) @map("category_id")
  categoryName   String    @map("category_name")
  vehicleType    String    @map("vehicle_type")
  commercialFlag Boolean   @default(false) @map("commercial_flag")
  status         String    @default("ACTIVE")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  cngSales       CngSale[]

  @@map("vehicle_category")
}

model CngSale {
  saleId      String          @id @default(cuid()) @map("sale_id")
  saleDate    DateTime        @map("sale_date")
  quantityScm Float           @map("quantity_scm")
  unitPrice   Float           @map("unit_price")
  amount      Float
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  stationId   String          @map("station_id")
  categoryId  String          @map("category_id")
  station     CngStation      @relation(fields: [stationId], references: [stationId])
  category    VehicleCategory @relation(fields: [categoryId], references: [categoryId])

  @@map("cng_sale")
}

model AppUser {
  appUserId       String              @id @default(cuid()) @map("app_user_id")
  mobile          String
  email           String?
  otpVerified     String              @default("N") @map("otp_verified")
  status          String              @default("ACTIVE")
  registeredAt    DateTime            @default(now()) @map("registered_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  customerId      String              @unique @map("customer_id")
  accountLinks    AppAccountLink[]
  devices         AppDevice[]
  notifications   AppNotification[]
  serviceRequests AppServiceRequest[]
  sessions        AppSession[]
  customer        Customer            @relation(fields: [customerId], references: [customerId])

  @@map("app_user")
}

model AppDevice {
  deviceId          String       @id @default(cuid()) @map("device_id")
  osType            String?      @map("os_type")
  appVersion        String?      @map("app_version")
  pushToken         String?      @map("push_token")
  deviceFingerprint String?      @map("device_fingerprint")
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  appUserId         String       @map("app_user_id")
  appUser           AppUser      @relation(fields: [appUserId], references: [appUserId])
  sessions          AppSession[]

  @@map("app_device")
}

model AppAccountLink {
  linkId        String   @id @default(cuid()) @map("link_id")
  ownershipType String?  @map("ownership_type")
  linkedAt      DateTime @default(now()) @map("linked_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  appUserId     String   @map("app_user_id")
  accountId     String   @map("account_id")
  appUser       AppUser  @relation(fields: [appUserId], references: [appUserId])
  account       Account  @relation(fields: [accountId], references: [accountId])

  @@map("app_account_link")
}

model AppSession {
  sessionId     String    @id @default(cuid()) @map("session_id")
  startedAt     DateTime  @default(now()) @map("started_at")
  endedAt       DateTime? @map("ended_at")
  sessionStatus String    @default("ACTIVE") @map("session_status")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  appUserId     String    @map("app_user_id")
  deviceId      String    @map("device_id")
  appUser       AppUser   @relation(fields: [appUserId], references: [appUserId])
  device        AppDevice @relation(fields: [deviceId], references: [deviceId])

  @@map("app_session")
}

model AppNotification {
  notifId    String        @id @default(cuid()) @map("notif_id")
  message    String?
  channel    String?
  sentAt     DateTime?     @map("sent_at")
  readFlag   Boolean       @default(false) @map("read_flag")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  appUserId  String        @map("app_user_id")
  templateId String        @map("template_id")
  appUser    AppUser       @relation(fields: [appUserId], references: [appUserId])
  template   NotifTemplate @relation(fields: [templateId], references: [templateId])

  @@map("app_notification")
}

model NotifTemplate {
  templateId    String            @id @default(cuid()) @map("template_id")
  channel       String
  eventType     String            @map("event_type")
  language      String            @default("en")
  bodyTemplate  String            @map("body_template")
  active        Boolean           @default(true)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
